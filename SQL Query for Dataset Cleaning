-- ------------------- Category-wise Sales Summary -------------------





-- Transaction-level Revenue KPI
SELECT 
   
    Category,
    Sub_Category,
    Sales AS Transaction_Revenue
FROM SuperstoreSalesDataset
ORDER BY Sales DESC;







-- Get number of orders, average, min, max, and total sales for each category
SELECT Category,
       COUNT(*) AS Num_Orders,         -- Total number of orders in this category
       AVG(Sales) AS Avg_Sales,        -- Average sales amount
       MIN(Sales) AS Min_Sales,        -- Minimum sales amount
       MAX(Sales) AS Max_Sales,        -- Maximum sales amount
       SUM(Sales) AS Total_Sales       -- Total sales
FROM SuperstoreSalesDataset
GROUP BY Category
ORDER BY Total_Sales DESC;


-- ------------------- Sales by Year and Quarter -------------------

-- Convert Order_Date from DD/MM/YYYY to YYYY-MM-DD
-- Calculate Year and Quarter for each order and summarize sales by category
SELECT
    substr(Order_Date, 7, 4) || '-' || substr(Order_Date, 4, 2) || '-' || substr(Order_Date, 1, 2) AS Proper_Date,  -- Proper date format
    substr(Order_Date, 7, 4) AS Year,                                 -- Extract year
    ((CAST(substr(Order_Date, 4, 2) AS INTEGER)-1)/3 + 1) AS Quarter, -- Calculate quarter (1 to 4)
    Category,
    SUM(Sales) AS Total_Sales,                                        -- Total sales for this category in the quarter
    AVG(Sales) AS Avg_Sales                                           -- Average sales for this category in the quarter
FROM SuperstoreSalesDataset
WHERE Order_Date IS NOT NULL
GROUP BY Year, Quarter, Category
ORDER BY year, sales DESC;


-- ------------------- Category & Sub-Category Sales Summary -------------------

-- Aggregate sales and order count by Category and Sub-Category
SELECT Category, sub_category, 
       ROUND(SUM(Sales), 2) AS Total_Sales,       -- Total sales rounded to 2 decimals
       ROUND(AVG(Sales), 2) AS Avg_Sale_Value,    -- Average sales rounded to 2 decimals
       COUNT(*) AS Total_Orders                    -- Total number of orders
FROM SuperstoreSalesDataset
GROUP BY Category, sub_category
ORDER BY Total_Sales DESC;


-- ------------------- Ship Mode Analysis -------------------

-- Count orders and calculate total and average sales by shipping mode
SELECT ship_mode, 
       COUNT(*) AS Order_Count,                    -- Number of orders per shipping mode
       ROUND(SUM(Sales), 2) AS Total_Sales,       -- Total sales per shipping mode
       ROUND(AVG(Sales), 2) AS Avg_Order_Value    -- Average sales per order
FROM SuperstoreSalesDataset
GROUP BY ship_mode
ORDER BY Avg_Order_Value DESC;


-- ------------------- Segment-wise Analysis -------------------

-- Count orders, total sales, and average sales for each customer segment
SELECT Segment,
       COUNT(*) AS OrderCount,                     -- Total number of orders per segment
       SUM(Sales) AS TotalSales,                   -- Total sales per segment
       AVG(Sales) AS AvgSales                      -- Average sales per segment
FROM SuperstoreSalesDataset
GROUP BY Segment;



-- Count orders, total sales, and average sales for each customer state
SELECT state,
       COUNT(*) AS OrderCount,                     -- Total number of orders per segment
       SUM(Sales) AS TotalSales,                   -- Total sales per segment
       AVG(Sales) AS AvgSales                      -- Average sales per segment
FROM SuperstoreSalesDataset
GROUP BY state
ORDER BY  TotalSales DESC;




-- ------------------- Lowest 5 Products by Sales -------------------
SELECT Category,
       Sub_Category,
       Product_ID,        -- or product name column
       SUM(Sales) AS Total_Sales
FROM SuperstoreSalesDataset
GROUP BY Category, Sub_Category, Product_ID
ORDER BY Total_Sales ASC
LIMIT 5;                 -- 5 products with lowest sales



-- Get products in the top 10% of sales with sales rank in percentage
SELECT * FROM (
    SELECT 
        product_name, 
        sub_category, 
        Sales,
        ROUND(PERCENT_RANK() OVER (ORDER BY Sales) * 100, 2) AS sales_rank_percent
    FROM SuperstoreSalesDataset
) t
WHERE sales_rank_percent > 90      -- top 10%
ORDER BY Sales DESC;


-- Count of orders per State and Ship Mode
SELECT 
    state,
    ship_mode,
    COUNT(*) AS Order_Count,
    ROUND(SUM(Sales), 2) AS Total_Sales
FROM SuperstoreSalesDataset
GROUP BY  ship_mode
ORDER BY ship_mode, Order_Count DESC;

-- Top customers by total sales
SELECT 
    customer_name,
    SUM(Sales) AS Total_Sales,
    COUNT(*) AS Total_Orders,
    ROUND(AVG(Sales), 2) AS Avg_Order_Value
FROM SuperstoreSalesDataset
GROUP BY customer_id
ORDER BY Total_Sales DESC
LIMIT 10;


-- Calculate total sales per region
SELECT 
    Region, 
    ROUND(SUM(Sales), 2) AS Regional_Sales
FROM SuperstoreSalesDataset
GROUP BY Region
ORDER BY Region, Regional_Sales DESC;


-- Calculate total sales per category within each region 
-- and the percentage contribution of each category to the region's total sales
SELECT 
    Region, 
    Category, 
    ROUND(SUM(Sales), 2) AS Regional_Sales,
    ROUND(
        (SUM(Sales) * 100.0 / SUM(SUM(Sales)) OVER(PARTITION BY Region)), 
        2
    ) AS Pct_of_Regional_Total
FROM SuperstoreSalesDataset
GROUP BY Region, Category
ORDER BY Region, Regional_Sales DESC;
